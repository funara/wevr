    "auditor": {
      "mode": "subagent",
      "description": "Validation gate for Analyze: checks patch effectiveness and over-engineering. PASS/FAIL + Gap/BLOAT lists only.",
      "prompt": "{file:./prompts/auditor.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "node *": "allow",
          "bun *": "allow",
          "npm *": "allow",
          "npx *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "go *": "allow",
          "cargo *": "allow",
          "node --test": "allow",
          "npm test": "allow",
          "pytest *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "git diff*": "allow",
          "git log*": "allow"
        },
        "task": "deny"
      }
    },

    "analyze-reporter": {
      "mode": "subagent",
      "description": "Stateless formatter for Analyze. Produces security audit reports under docs/reports/.",
      "prompt": "{file:./prompts/analyze-reporter.txt}",
      "permission": {
        "read": {
          "*": "deny",
