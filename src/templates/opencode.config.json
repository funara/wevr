{
  "$schema": "https://opencode.ai/config.json",
  "theme": "wevr-contrast",
  "instructions": ["{file:./prompts/hierarchy.txt}"],
  "permission": {
    "read": {
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    },
    "edit": {
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    },
    "write": {
      "*.env": "deny",
      "*.env.*": "deny",
      "secrets/**": "deny"
    }
  },
  "agent": {
    "plan": { "hidden": true },
    "build": { "hidden": true },

    "compose": {
      "mode": "primary",
      "color": "#00b4cc",
      "temperature": 0.7,
      "description": "Full engineering workflow: Explore, Plan, Build — 3 phases, 7 subagents. Starts in Explore mode, transitions via guardrail gates.",
      "prompt": "{file:./prompts/compose.txt}",
      "permission": {
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "edit": "deny",
        "write": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "question": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "researcher": "allow",
          "plan-writer": "allow",
          "plan-checker": "allow",
          "coder": "allow",
          "tester": "allow",
          "reviewer": "allow",
          "compose-reporter": "allow"
        }
      }
    },


    "debug": {
      "mode": "primary",
      "color": "#ff7039",
      "description": "Root-cause analysis via inspector/fixer/reporter. Standalone primary agent — does not depend on Compose. Pure orchestrator — all investigation, fixes, and reports delegated to subagents.",
      "prompt": "{file:./prompts/debug.txt}",
      "permission": {
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "edit": "deny",
        "write": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "question": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "inspector": "allow",
          "fixer": "allow",
          "debug-reporter": "allow"
        }
      }
    },

    "analyze": {
      "mode": "primary",
      "color": "#66ffbf",
      "temperature": 0.7,
      "description": "Standalone security and quality auditing agent. Recon and vuln trace, minimal patch application, validation gate.",
      "prompt": "{file:./prompts/analyze.txt}",
      "permission": {
        "read": "deny",
        "glob": "deny",
        "grep": "deny",
        "edit": "deny",
        "write": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "bash": "deny",
        "question": "allow",
        "todowrite": "allow",
        "task": {
          "*": "deny",
          "tracer": "allow",
          "patcher": "allow",
          "auditor": "allow",
          "analyze-reporter": "allow"
        }
      }
    },

    "coder": {
      "mode": "subagent",
      "description": "Implements tasks assigned by Compose, following the PRD exactly. Tracks own progress via todowrite.",
      "prompt": "{file:./prompts/coder.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "bash": {
          "*": "deny",
          "npm *": "allow",
          "npx *": "allow",
          "node *": "allow",
          "bun *": "allow",
          "pnpm *": "allow",
          "yarn *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "pip *": "allow",
          "pip3 *": "allow",
          "uv *": "allow",
          "poetry *": "allow",
          "go *": "allow",
          "cargo *": "allow",
          "make *": "allow",
          "cmake *": "allow",
          "git *": "allow",
          "mkdir *": "allow",
          "cp *": "allow",
          "rm *": "allow",
          "mv *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "echo *": "allow",
          "node --test": "allow",
          "npm test": "allow",
          "pytest *": "allow"
        },
        "task": "deny"
      }
    },

    "tester": {
      "mode": "subagent",
      "description": "Runs tests on implemented code and reports results (PASS/FAIL/BLOCKED) with coverage gaps. Cannot fix code, install deps, or decide next steps.",
      "prompt": "{file:./prompts/tester.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "todowrite": "deny",
        "bash": {
          "*": "deny",
          "node *": "allow",
          "bun *": "allow",
          "npm *": "allow",
          "npx *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "go *": "allow",
          "cargo *": "allow",
          "node --test": "allow",
          "npm test": "allow",
          "pytest *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "echo *": "allow"
        },
        "task": "deny"
      }
    },

    "reviewer": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Compose: compares implementation against PRD definition-of-done. PASS/FAIL + gap list only.",
      "prompt": "{file:./prompts/reviewer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow"
        },
        "task": "deny"
      }
    },

    "compose-reporter": {
      "mode": "subagent",
      "description": "Text-file executor for Compose. Writes and edits .md/.txt files under docs/ — stateless formatter for documents only. No bash.",
      "prompt": "{file:./prompts/compose-reporter.txt}",
      "permission": {
        "read": {
          "*": "deny",
          "docs/**": "allow"
        },
        "glob": "deny",
        "grep": "deny",
        "edit": {
          "*": "deny",
          "docs/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/**": "allow"
        },
        "bash": "deny",
        "todowrite": "deny",
        "task": "deny"
      }
    },


    "researcher": {
      "mode": "subagent",
      "description": "Researches technical and codebase context for Compose during EXPLORE phase. Outputs confirmed_facts / inferred_facts / unknowns / risks only.",
      "prompt": "{file:./prompts/researcher.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "node --version": "allow",
          "npm --version": "allow",
          "python --version": "allow",
          "python3 --version": "allow",
          "go version": "allow",
          "cargo --version": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny"
      }
    },

    "plan-writer": {
      "mode": "subagent",
      "description": "Stateless formatter for Compose. Produces PRD documents from structured input — no inference, no decisions. PRD mode only.",
      "prompt": "{file:./prompts/plan-writer.txt}",
      "permission": {
        "read": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "glob": "deny",
        "grep": "deny",
        "edit": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/plans/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    },

    "plan-checker": {
      "mode": "subagent",
      "temperature": 0.1,
      "description": "Boolean gate for Compose: checks PRD completeness against original user request. PASS/FAIL + gap list only.",
      "prompt": "{file:./prompts/plan-checker.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "grep *": "allow"
        },
        "task": "deny"
      }
    },

    "inspector": {
      "mode": "subagent",
      "description": "Root-cause analysis for Debug. Investigates bugs via codebase and web research. Outputs confirmed_facts / inferred_facts / unknowns / risks only.",
      "prompt": "{file:./prompts/inspector.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "git status*": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "cat *": "allow",
          "find *": "allow",
          "ls *": "allow",
          "dir *": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "task": "deny"
      }
    },

    "fixer": {
      "mode": "subagent",
      "description": "Implements bug fixes for Debug. Follows root cause from inspector. Like coder but focused on fixes — minimal change, root-cause targeting.",
      "prompt": "{file:./prompts/fixer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "todowrite": "allow",
        "bash": {
          "*": "deny",
          "npm *": "allow",
          "npx *": "allow",
          "node *": "allow",
          "bun *": "allow",
          "pnpm *": "allow",
          "yarn *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "pip *": "allow",
          "pip3 *": "allow",
          "uv *": "allow",
          "poetry *": "allow",
          "go *": "allow",
          "cargo *": "allow",
          "make *": "allow",
          "cmake *": "allow",
          "git *": "allow",
          "mkdir *": "allow",
          "cp *": "allow",
          "rm *": "allow",
          "mv *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "echo *": "allow",
          "node --test": "allow",
          "npm test": "allow",
          "pytest *": "allow"
        },
        "task": "deny"
      }
    },

    "debug-reporter": {
      "mode": "subagent",
      "description": "Stateless formatter for Debug. Produces diagnosis + remedy reports from structured input — no inference, no decisions. Summary mode only.",
      "prompt": "{file:./prompts/debug-reporter.txt}",
      "permission": {
        "read": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "glob": "deny",
        "grep": "deny",
        "edit": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "write": {
          "*": "deny",
          "docs/reports/**": "allow"
        },
        "bash": "deny",
        "task": "deny"
      }
    },


    "tracer": {
      "mode": "subagent",
      "description": "Recon attack surface and trace vulnerability paths for Analyze. Guided by WSTG and secure code review practices.",
      "prompt": "{file:./prompts/tracer.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "deny",
        "write": "deny",
        "bash": {
          "*": "deny",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "git log*": "allow",
          "git diff*": "allow",
          "git show*": "allow",
          "git blame*": "allow",
          "node --version": "allow",
          "npm --version": "allow",
          "python --version": "allow",
          "python3 --version": "allow",
          "go version": "allow",
          "cargo --version": "allow",
          "which *": "allow",
          "where *": "allow"
        },
        "task": "deny"
      }
    },

    "patcher": {
      "mode": "subagent",
      "description": "Applies minimal, security-targeted patches for Analyze using Ponytail mindset.",
      "prompt": "{file:./prompts/patcher.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "write": "allow",
        "bash": {
          "*": "deny",
          "npm *": "allow",
          "npx *": "allow",
          "node *": "allow",
          "bun *": "allow",
          "pnpm *": "allow",
          "yarn *": "allow",
          "python *": "allow",
          "python3 *": "allow",
          "pip *": "allow",
          "pip3 *": "allow",
          "uv *": "allow",
          "poetry *": "allow",
          "go *": "allow",
          "cargo *": "allow",
          "make *": "allow",
          "cmake *": "allow",
          "git *": "allow",
          "mkdir *": "allow",
          "cp *": "allow",
          "rm *": "allow",
          "mv *": "allow",
          "cat *": "allow",
          "ls *": "allow",
          "dir *": "allow",
          "rg *": "allow",
          "grep *": "allow",
          "find *": "allow",
          "echo *": "allow",
          "node --test": "allow",
          "npm test": "allow",
          "pytest *": "allow"
